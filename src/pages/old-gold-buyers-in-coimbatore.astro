---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Old Gold Buyers in Coimbatore - Best Price for Old Gold | MRG Gold"
  description="Sell your old gold jewelry in Coimbatore at the best market rates. We buy old, unused, and vintage gold with transparent pricing and instant payment."
>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="relative pt-24 pb-12 sm:pb-16 lg:pb-20 bg-gradient-to-br from-gray-900 via-[#2D031A] to-black">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center text-white">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black mb-6">
            <span class="text-[#C65B91]">Old Gold Buyers</span> in Coimbatore
          </h1>
          <p class="text-lg sm:text-xl text-gray-200 max-w-3xl mx-auto mb-8">
            Turn your old, unused gold into instant cash. We offer the highest market prices for vintage gold jewelry, antique ornaments, and inherited gold items.
          </p>
          <a href="tel:+917200090326" class="inline-flex items-center justify-center bg-[#7C0849] hover:bg-[#650738] text-white font-bold px-8 py-4 rounded-lg transition-colors">
            Get Free Evaluation - Call +91 72000 90326
          </a>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12 sm:py-16 lg:py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto mb-12 text-center">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Trusted Old Gold Buyers in Coimbatore</h2>
          <p class="text-lg text-gray-600 leading-relaxed">
            Have old gold jewelry sitting idle in your locker? Convert it into instant cash with MRG Gold Buyers. We specialize in buying old, vintage, and antique gold ornaments at the best market rates with complete transparency.
          </p>
        </div>

        <!-- Types of Old Gold We Buy -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-gray-900 text-center mb-8">Types of Old Gold We Buy</h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
              <div class="flex items-center mb-3">
                <div class="w-10 h-10 bg-[#7C0849] rounded-full flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Old Jewelry</h4>
              </div>
              <p class="text-gray-600 text-sm">Outdated designs, unused necklaces, bangles, earrings</p>
            </div>

            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
              <div class="flex items-center mb-3">
                <div class="w-10 h-10 bg-[#7C0849] rounded-full flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Vintage Gold</h4>
              </div>
              <p class="text-gray-600 text-sm">Antique ornaments, traditional designs, heritage pieces</p>
            </div>

            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
              <div class="flex items-center mb-3">
                <div class="w-10 h-10 bg-[#7C0849] rounded-full flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Broken Items</h4>
              </div>
              <p class="text-gray-600 text-sm">Damaged ornaments, broken chains, twisted bangles</p>
            </div>

            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
              <div class="flex items-center mb-3">
                <div class="w-10 h-10 bg-[#7C0849] rounded-full flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Inherited Gold</h4>
              </div>
              <p class="text-gray-600 text-sm">Family heirloom pieces, grandparents' jewelry</p>
            </div>

            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
              <div class="flex items-center mb-3">
                <div class="w-10 h-10 bg-[#7C0849] rounded-full flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Old Coins</h4>
              </div>
              <p class="text-gray-600 text-sm">Vintage gold coins, old currency, collectibles</p>
            </div>

            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
              <div class="flex items-center mb-3">
                <div class="w-10 h-10 bg-[#7C0849] rounded-full flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Scrap Gold</h4>
              </div>
              <p class="text-gray-600 text-sm">Gold scrap, melted pieces, irregular shapes</p>
            </div>
          </div>
        </div>

        <!-- Why Sell Old Gold to Us -->
        <div class="bg-gradient-to-br from-[#F8E8F1] to-white rounded-2xl p-8 sm:p-12 mb-16">
          <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">Why Sell Your Old Gold to Us?</h3>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold text-xl">1</div>
              <div>
                <h4 class="font-bold text-gray-900 mb-2">Best Market Rates</h4>
                <p class="text-gray-600">We guarantee the highest price for your old gold based on current market rates. No lowball offers.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold text-xl">2</div>
              <div>
                <h4 class="font-bold text-gray-900 mb-2">Professional Testing</h4>
                <p class="text-gray-600">Advanced gold testing equipment to accurately determine purity - 18K, 22K, 24K, or any karat.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold text-xl">3</div>
              <div>
                <h4 class="font-bold text-gray-900 mb-2">Zero Melting Charges</h4>
                <p class="text-gray-600">Unlike others, we don't deduct melting, testing, or any hidden charges. Full value for your gold.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold text-xl">4</div>
              <div>
                <h4 class="font-bold text-gray-900 mb-2">Instant Cash Payment</h4>
                <p class="text-gray-600">Walk out with cash in hand or get instant bank transfer/UPI payment immediately after evaluation.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold text-xl">5</div>
              <div>
                <h4 class="font-bold text-gray-900 mb-2">Safe & Secure</h4>
                <p class="text-gray-600">Secure premises with CCTV surveillance. Your safety and privacy are our top priorities.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold text-xl">6</div>
              <div>
                <h4 class="font-bold text-gray-900 mb-2">Doorstep Service</h4>
                <p class="text-gray-600">Free home visit for gold evaluation. Our experts come to your location with all equipment.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Benefits Section -->
        <div class="text-center mb-12">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Benefits of Selling Old Gold</h3>
          <div class="max-w-3xl mx-auto">
            <div class="grid sm:grid-cols-2 gap-6 text-left">
              <div class="flex items-start space-x-3">
                <svg class="w-6 h-6 text-[#7C0849] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <p class="text-gray-600">Free up locker space occupied by unused jewelry</p>
              </div>
              <div class="flex items-start space-x-3">
                <svg class="w-6 h-6 text-[#7C0849] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <p class="text-gray-600">Get instant cash for emergency needs</p>
              </div>
              <div class="flex items-start space-x-3">
                <svg class="w-6 h-6 text-[#7C0849] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <p class="text-gray-600">Better than letting gold sit idle and lose value</p>
              </div>
              <div class="flex items-start space-x-3">
                <svg class="w-6 h-6 text-[#7C0849] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <p class="text-gray-600">Use the money to redesign into modern jewelry</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-12 sm:py-16 bg-gradient-to-br from-[#7C0849] to-[#4E052B]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">Ready to Sell Your Old Gold?</h2>
        <p class="text-xl mb-8 text-[#F1D1E2]">Get the best value for your old jewelry today. Free evaluation, instant payment!</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+917200090326" class="inline-flex items-center justify-center bg-white text-[#7C0849] font-bold px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors">
            Call +91 72000 90326
          </a>
          <a href="https://wa.me/917200090326" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[#A7356D] hover:bg-[#650738] text-white font-bold px-8 py-4 rounded-lg transition-colors">
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>

    <div id="contact"></div>
  </main>
  <Footer />
</Layout>
