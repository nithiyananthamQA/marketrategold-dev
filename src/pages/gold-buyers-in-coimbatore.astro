---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Gold Buyers in Coimbatore - Best Gold Buying Services | MRG Gold"
  description="Leading gold buyers in Coimbatore offering highest market rates for all types of gold jewelry, coins, and ornaments. Transparent evaluation, instant payment, free doorstep service."
>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="relative pt-24 pb-12 sm:pb-16 lg:pb-20 bg-gradient-to-br from-gray-900 via-[#2D031A] to-black">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center text-white">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black mb-6">
            Trusted <span class="text-[#C65B91]">Gold Buyers</span> in Coimbatore
          </h1>
          <p class="text-lg sm:text-xl text-gray-200 max-w-3xl mx-auto mb-8">
            Get the best value for your gold with our transparent evaluation process and instant cash payment. Serving Coimbatore, Tiruppur, and Theni.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="tel:+917200090326" class="inline-flex items-center justify-center bg-[#7C0849] hover:bg-[#650738] text-white font-bold px-8 py-4 rounded-lg transition-colors">
              Call +91 72000 90326
            </a>
            <a href="#contact" class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-lg border-2 border-white/50 transition-colors">
              Get Free Quote
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12 sm:py-16 lg:py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-12">
          <!-- Left Content -->
          <div class="lg:col-span-2 space-y-8">
            <div>
              <h2 class="text-3xl font-bold text-gray-900 mb-4">Why Choose MRG Gold Buyers in Coimbatore?</h2>
              <p class="text-gray-700 leading-relaxed mb-6">
                MRG Gold Buyers is Coimbatore's most trusted gold buying service, offering the highest market rates for all types of gold jewelry, coins, and ornaments. With years of experience in the gold industry, we provide transparent, hassle-free gold buying services with instant cash payment.
              </p>
              <p class="text-gray-700 leading-relaxed">
                Whether you have old gold jewelry, broken ornaments, gold coins, or pledged gold, we offer the best prices based on current market rates with complete transparency throughout the evaluation process.
              </p>
            </div>

            <div>
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Types of Gold We Buy</h3>
              <div class="grid sm:grid-cols-2 gap-4">
                <div class="flex items-start space-x-3">
                  <svg class="w-6 h-6 text-[#7C0849] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <div>
                    <h4 class="font-semibold text-gray-900">Gold Jewelry</h4>
                    <p class="text-sm text-gray-600">Necklaces, rings, bangles, chains</p>
                  </div>
                </div>
                <div class="flex items-start space-x-3">
                  <svg class="w-6 h-6 text-[#7C0849] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <div>
                    <h4 class="font-semibold text-gray-900">Broken Gold</h4>
                    <p class="text-sm text-gray-600">Damaged or broken ornaments</p>
                  </div>
                </div>
                <div class="flex items-start space-x-3">
                  <svg class="w-6 h-6 text-[#7C0849] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <div>
                    <h4 class="font-semibold text-gray-900">Gold Coins & Bars</h4>
                    <p class="text-sm text-gray-600">Investment gold, bullion</p>
                  </div>
                </div>
                <div class="flex items-start space-x-3">
                  <svg class="w-6 h-6 text-[#7C0849] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <div>
                    <h4 class="font-semibold text-gray-900">Pledged Gold</h4>
                    <p class="text-sm text-gray-600">Release your pledged items</p>
                  </div>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Our Gold Buying Process</h3>
              <div class="space-y-4">
                <div class="flex">
                  <div class="flex-shrink-0 w-10 h-10 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold">1</div>
                  <div class="ml-4">
                    <h4 class="font-semibold text-gray-900">Contact Us</h4>
                    <p class="text-gray-600">Call us or visit our branch with your gold items</p>
                  </div>
                </div>
                <div class="flex">
                  <div class="flex-shrink-0 w-10 h-10 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold">2</div>
                  <div class="ml-4">
                    <h4 class="font-semibold text-gray-900">Professional Testing</h4>
                    <p class="text-gray-600">Gold purity and weight verification in front of you</p>
                  </div>
                </div>
                <div class="flex">
                  <div class="flex-shrink-0 w-10 h-10 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold">3</div>
                  <div class="ml-4">
                    <h4 class="font-semibold text-gray-900">Best Price Quote</h4>
                    <p class="text-gray-600">Get highest market rate for your gold</p>
                  </div>
                </div>
                <div class="flex">
                  <div class="flex-shrink-0 w-10 h-10 bg-[#7C0849] text-white rounded-full flex items-center justify-center font-bold">4</div>
                  <div class="ml-4">
                    <h4 class="font-semibold text-gray-900">Instant Payment</h4>
                    <p class="text-gray-600">Receive cash, bank transfer, or UPI immediately</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Sidebar -->
          <div class="lg:col-span-1">
            <div class="bg-gradient-to-br from-[#F8E8F1] to-white rounded-2xl p-6 sm:p-8 shadow-lg sticky top-24">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Quick Contact</h3>
              <div class="space-y-4">
                <a href="tel:+917200090326" class="flex items-center space-x-3 text-gray-700 hover:text-[#7C0849] transition">
                  <svg class="w-6 h-6 text-[#7C0849]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                  </svg>
                  <span class="font-semibold">+91 72000 90326</span>
                </a>
                <a href="mailto:marketrategold@gmail.com" class="flex items-center space-x-3 text-gray-700 hover:text-[#7C0849] transition">
                  <svg class="w-6 h-6 text-[#7C0849]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                  </svg>
                  <span class="font-semibold">marketrategold@gmail.com</span>
                </a>
              </div>

              <div class="mt-8 pt-8 border-t border-gray-200">
                <h4 class="font-bold text-gray-900 mb-4">Service Areas</h4>
                <ul class="space-y-2 text-gray-600">
                  <li class="flex items-center">
                    <span class="w-2 h-2 bg-[#7C0849] rounded-full mr-2"></span>
                    Coimbatore
                  </li>
                  <li class="flex items-center">
                    <span class="w-2 h-2 bg-[#7C0849] rounded-full mr-2"></span>
                    Tiruppur
                  </li>
                  <li class="flex items-center">
                    <span class="w-2 h-2 bg-[#7C0849] rounded-full mr-2"></span>
                    Theni
                  </li>
                </ul>
              </div>

              <div class="mt-8">
                <a href="#contact" class="block w-full bg-[#7C0849] hover:bg-[#650738] text-white text-center font-bold py-4 rounded-lg transition-colors">
                  Get Free Valuation
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-12 sm:py-16 bg-gradient-to-br from-[#7C0849] to-[#4E052B]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">Ready to Sell Your Gold?</h2>
        <p class="text-xl mb-8 text-[#F1D1E2]">Get the best price for your gold today. Free evaluation, instant payment!</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+917200090326" class="inline-flex items-center justify-center bg-white text-[#7C0849] font-bold px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors">
            Call Now
          </a>
          <a href="https://wa.me/917200090326" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[#A7356D] hover:bg-[#650738] text-white font-bold px-8 py-4 rounded-lg transition-colors">
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>

    <div id="contact"></div>
  </main>
  <Footer />
</Layout>
