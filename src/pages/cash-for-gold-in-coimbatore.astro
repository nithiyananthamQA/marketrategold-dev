---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Cash for Gold in Coimbatore - Instant Cash Payment | MRG Gold Buyers"
  description="Get instant cash for your gold in Coimbatore. Best market rates, transparent evaluation, immediate payment via cash, bank transfer, or UPI. Free doorstep service available."
>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="relative pt-24 pb-12 sm:pb-16 lg:pb-20 bg-gradient-to-br from-gray-900 via-[#2D031A] to-black">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center text-white">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black mb-6">
            Instant <span class="text-[#C65B91]">Cash for Gold</span> in Coimbatore
          </h1>
          <p class="text-lg sm:text-xl text-gray-200 max-w-3xl mx-auto mb-8">
            Turn your gold into instant cash! Get paid immediately with the highest market rates. No waiting, no delays - instant cash in hand.
          </p>
          <div class="flex flex-wrap gap-4 justify-center text-sm sm:text-base">
            <div class="flex items-center space-x-2 bg-white/10 px-4 py-2 rounded-full">
              <svg class="w-5 h-5 text-[#C65B91]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Instant Payment</span>
            </div>
            <div class="flex items-center space-x-2 bg-white/10 px-4 py-2 rounded-full">
              <svg class="w-5 h-5 text-[#C65B91]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Best Market Rate</span>
            </div>
            <div class="flex items-center space-x-2 bg-white/10 px-4 py-2 rounded-full">
              <svg class="w-5 h-5 text-[#C65B91]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Zero Deductions</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-12 sm:py-16 lg:py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Why Choose Our Cash for Gold Service?</h2>
          <p class="text-xl text-gray-600">Fast, transparent, and trustworthy gold buying service</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
            <div class="w-12 h-12 bg-[#7C0849] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Immediate Payment</h3>
            <p class="text-gray-600">Get instant cash, bank transfer, or UPI payment within minutes of evaluation.</p>
          </div>

          <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
            <div class="w-12 h-12 bg-[#7C0849] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Highest Market Rate</h3>
            <p class="text-gray-600">We offer the best price for your gold based on current market rates with zero deductions.</p>
          </div>

          <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
            <div class="w-12 h-12 bg-[#7C0849] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">100% Transparent</h3>
            <p class="text-gray-600">Gold testing and weighing done transparently in front of you with professional equipment.</p>
          </div>

          <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
            <div class="w-12 h-12 bg-[#7C0849] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Doorstep Service</h3>
            <p class="text-gray-600">Free home visit service available. Our experts come to your location for safe evaluation.</p>
          </div>

          <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
            <div class="w-12 h-12 bg-[#7C0849] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">No Hidden Charges</h3>
            <p class="text-gray-600">What you see is what you get. No hidden deductions, fees, or charges of any kind.</p>
          </div>

          <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 shadow-lg border border-[#F1D1E2]">
            <div class="w-12 h-12 bg-[#7C0849] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Trusted & Certified</h3>
            <p class="text-gray-600">Years of trusted service with thousands of satisfied customers across Tamil Nadu.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Payment Options -->
    <section class="py-12 sm:py-16 bg-gradient-to-br from-[#F8E8F1] to-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Flexible Payment Options</h2>
          <p class="text-xl text-gray-600">Choose how you want to receive your money</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center p-6 bg-white rounded-xl shadow-lg">
            <div class="w-16 h-16 bg-[#F1D1E2] rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl">💵</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Instant Cash</h3>
            <p class="text-gray-600">Get immediate cash payment in hand</p>
          </div>

          <div class="text-center p-6 bg-white rounded-xl shadow-lg">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl">🏦</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Bank Transfer</h3>
            <p class="text-gray-600">Direct NEFT/RTGS/IMPS to your account</p>
          </div>

          <div class="text-center p-6 bg-white rounded-xl shadow-lg">
            <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl">📱</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">UPI Payment</h3>
            <p class="text-gray-600">Instant UPI transfer - Google Pay, PhonePe, Paytm</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-12 sm:py-16 bg-gradient-to-br from-[#7C0849] to-[#4E052B]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">Get Instant Cash for Your Gold Today!</h2>
        <p class="text-xl mb-8 text-[#F1D1E2]">Call us now for free evaluation and instant payment</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+917200090326" class="inline-flex items-center justify-center bg-white text-[#7C0849] font-bold px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            Call +91 72000 90326
          </a>
          <a href="https://wa.me/917200090326" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[#A7356D] hover:bg-[#650738] text-white font-bold px-8 py-4 rounded-lg transition-colors">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>

    <div id="contact"></div>
  </main>
  <Footer />
</Layout>
