---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Second Hand Old Gold Buyers in Coimbatore | MRG Gold Buyers"
  description="Sell your second-hand gold jewelry in Coimbatore at the best prices. We buy pre-owned, used gold ornaments with transparent pricing and instant cash payment."
>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="relative pt-24 pb-12 sm:pb-16 lg:pb-20 bg-gradient-to-br from-gray-900 via-[#2D031A] to-black">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center text-white">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black mb-6">
            <span class="text-[#C65B91]">Second Hand Gold Buyers</span> in Coimbatore
          </h1>
          <p class="text-lg sm:text-xl text-gray-200 max-w-3xl mx-auto mb-8">
            Best prices for pre-owned and second-hand gold jewelry. Turn your used gold into instant cash with transparent evaluation and highest market rates.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="tel:+917200090326" class="inline-flex items-center justify-center bg-[#7C0849] hover:bg-[#650738] text-white font-bold px-8 py-4 rounded-lg transition-colors">
              Call for Quote
            </a>
            <a href="https://wa.me/917200090326" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[#25D366] hover:bg-[#128C7E] text-white font-bold px-8 py-4 rounded-lg transition-colors">
              WhatsApp Now
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12 sm:py-16 lg:py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4 text-center">Trusted Second Hand Gold Buyers</h2>
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            MRG Gold Buyers is Coimbatore's leading buyer of second-hand and pre-owned gold jewelry. Whether you have used gold ornaments, previously owned jewelry, or gold items you no longer need, we offer the best prices with complete transparency and instant payment.
          </p>
          <p class="text-lg text-gray-700 leading-relaxed">
            We understand that second-hand gold has the same intrinsic value as new gold. That's why we judge your gold purely on its weight and purity, not its condition or appearance.
          </p>
        </div>

        <!-- What We Buy -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-gray-900 text-center mb-8">Second Hand Gold Items We Buy</h3>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 text-center shadow-lg border border-[#F1D1E2]">
              <div class="w-16 h-16 bg-[#F1D1E2] rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl">💍</span>
              </div>
              <h4 class="font-bold text-gray-900 mb-2">Used Jewelry</h4>
              <p class="text-sm text-gray-600">Worn necklaces, used bangles, pre-owned rings</p>
            </div>

            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 text-center shadow-lg border border-[#F1D1E2]">
              <div class="w-16 h-16 bg-[#F1D1E2] rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl">👑</span>
              </div>
              <h4 class="font-bold text-gray-900 mb-2">Old Ornaments</h4>
              <p class="text-sm text-gray-600">Outdated designs, traditional jewelry</p>
            </div>

            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 text-center shadow-lg border border-[#F1D1E2]">
              <div class="w-16 h-16 bg-[#F1D1E2] rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl">🔗</span>
              </div>
              <h4 class="font-bold text-gray-900 mb-2">Broken Gold</h4>
              <p class="text-sm text-gray-600">Damaged items, broken chains, twisted pieces</p>
            </div>

            <div class="bg-gradient-to-br from-white to-[#F8E8F1] rounded-xl p-6 text-center shadow-lg border border-[#F1D1E2]">
              <div class="w-16 h-16 bg-[#F1D1E2] rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl">🪙</span>
              </div>
              <h4 class="font-bold text-gray-900 mb-2">Gold Coins</h4>
              <p class="text-sm text-gray-600">Pre-owned coins, old gold bars</p>
            </div>
          </div>
        </div>

        <!-- Key Features -->
        <div class="bg-gradient-to-br from-[#F8E8F1] to-white rounded-2xl p-8 sm:p-12 mb-16">
          <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">Why We're the Best Choice</h3>
          <div class="grid md:grid-cols-3 gap-8">
            <div class="text-center">
              <div class="w-20 h-20 bg-[#7C0849] rounded-2xl flex items-center justify-center mx-auto mb-4 transform rotate-3">
                <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h4 class="font-bold text-gray-900 mb-2">Best Market Rates</h4>
              <p class="text-gray-600">Highest prices for second-hand gold based on current market rates</p>
            </div>

            <div class="text-center">
              <div class="w-20 h-20 bg-[#7C0849] rounded-2xl flex items-center justify-center mx-auto mb-4 transform -rotate-3">
                <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h4 class="font-bold text-gray-900 mb-2">100% Transparent</h4>
              <p class="text-gray-600">Live testing and weighing in front of you with professional equipment</p>
            </div>

            <div class="text-center">
              <div class="w-20 h-20 bg-[#7C0849] rounded-2xl flex items-center justify-center mx-auto mb-4 transform rotate-3">
                <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h4 class="font-bold text-gray-900 mb-2">Instant Payment</h4>
              <p class="text-gray-600">Immediate cash, bank transfer, or UPI payment on the spot</p>
            </div>
          </div>
        </div>

        <!-- Our Process -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-gray-900 text-center mb-8">Simple 4-Step Process</h3>
          <div class="max-w-4xl mx-auto">
            <div class="relative">
              <!-- Vertical line -->
              <div class="absolute left-6 top-6 bottom-6 w-0.5 bg-[#E3A3C5] hidden sm:block"></div>
              
              <div class="space-y-8">
                <div class="relative flex items-start space-x-4">
                  <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-[#7C0849] to-[#650738] text-white rounded-full flex items-center justify-center font-bold text-xl shadow-lg z-10">1</div>
                  <div class="flex-1 bg-white rounded-xl p-6 shadow-lg">
                    <h4 class="font-bold text-gray-900 mb-2">Bring Your Gold</h4>
                    <p class="text-gray-600">Visit our branch with your second-hand gold items. No appointment needed!</p>
                  </div>
                </div>

                <div class="relative flex items-start space-x-4">
                  <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-[#7C0849] to-[#650738] text-white rounded-full flex items-center justify-center font-bold text-xl shadow-lg z-10">2</div>
                  <div class="flex-1 bg-white rounded-xl p-6 shadow-lg">
                    <h4 class="font-bold text-gray-900 mb-2">Professional Testing</h4>
                    <p class="text-gray-600">We test purity and weigh your gold transparently in front of you using calibrated equipment.</p>
                  </div>
                </div>

                <div class="relative flex items-start space-x-4">
                  <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-[#7C0849] to-[#650738] text-white rounded-full flex items-center justify-center font-bold text-xl shadow-lg z-10">3</div>
                  <div class="flex-1 bg-white rounded-xl p-6 shadow-lg">
                    <h4 class="font-bold text-gray-900 mb-2">Get Best Quote</h4>
                    <p class="text-gray-600">Receive highest market rate quote instantly. No hidden charges or deductions.</p>
                  </div>
                </div>

                <div class="relative flex items-start space-x-4">
                  <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-[#7C0849] to-[#650738] text-white rounded-full flex items-center justify-center font-bold text-xl shadow-lg z-10">4</div>
                  <div class="flex-1 bg-white rounded-xl p-6 shadow-lg">
                    <h4 class="font-bold text-gray-900 mb-2">Instant Cash</h4>
                    <p class="text-gray-600">Walk out with cash in hand or get immediate bank transfer/UPI payment.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Service Areas -->
        <div class="text-center max-w-3xl mx-auto">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Service Areas</h3>
          <p class="text-gray-600 mb-6">We serve customers across Tamil Nadu with our trusted second-hand gold buying services:</p>
          <div class="flex flex-wrap justify-center gap-4">
            <span class="bg-[#F1D1E2] text-[#4E052B] px-4 py-2 rounded-full font-semibold">Coimbatore</span>
            <span class="bg-[#F1D1E2] text-[#4E052B] px-4 py-2 rounded-full font-semibold">Tiruppur</span>
            <span class="bg-[#F1D1E2] text-[#4E052B] px-4 py-2 rounded-full font-semibold">Theni</span>
            <span class="bg-[#F1D1E2] text-[#4E052B] px-4 py-2 rounded-full font-semibold">Erode</span>
            <span class="bg-[#F1D1E2] text-[#4E052B] px-4 py-2 rounded-full font-semibold">Salem</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-12 sm:py-16 bg-gradient-to-br from-[#7C0849] to-[#4E052B]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">Sell Your Second Hand Gold Today!</h2>
        <p class="text-xl mb-8 text-[#F1D1E2]">Get the best price for your pre-owned gold. Free evaluation, instant cash payment!</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+917200090326" class="inline-flex items-center justify-center bg-white text-[#7C0849] font-bold px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            Call +91 72000 90326
          </a>
          <a href="/" class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-lg border-2 border-white/50 transition-colors">
            Visit Homepage
          </a>
        </div>
      </div>
    </section>

    <div id="contact"></div>
  </main>
  <Footer />
</Layout>
