---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title = 'MRG Gold Buyers - Sell Gold at Highest Market Rate in Coimbatore',
  description = 'Trusted gold buyers in Coimbatore, Tiruppur & Theni. Get instant cash for gold with transparent evaluation, doorstep service & highest market rates. Free gold valuation!'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://marketrategold.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://marketrategold.com/images/og-image.jpg" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://marketrategold.com/images/og-image.jpg" />
    
    <!-- Local Business Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "MRG Gold Buyers",
        "image": "https://marketrategold.com/images/logo.png",
        "description": "Trusted gold buyers in Coimbatore offering highest market rates for old gold",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Coimbatore",
          "addressRegion": "Tamil Nadu",
          "addressCountry": "IN"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 11.0168,
          "longitude": 76.9558
        },
        "url": "https://marketrategold.com",
        "telephone": "+91-7200090326",
        "priceRange": "₹₹₹",
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
            "opens": "09:00",
            "closes": "18:00"
          }
        ],
        "areaServed": [
          {
            "@type": "City",
            "name": "Coimbatore"
          },
          {
            "@type": "City",
            "name": "Tiruppur"
          },
          {
            "@type": "City",
            "name": "Theni"
          }
        ]
      }
    </script>
    <!-- DNS Prefetch for Images -->
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* High-performance system font stacks */
    --font-heading: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
    --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
  }
  
  body {
    font-family: var(--font-body);
  }
  
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
  }
</style>
