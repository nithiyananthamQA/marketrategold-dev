---
// No dependencies - pure HTML/CSS hero section
---

<section id="home" class="relative w-full min-h-[650px] sm:min-h-[700px] lg:min-h-[800px] h-auto lg:h-[90vh] max-h-[900px] bg-gradient-to-br from-gray-900 via-red-950 to-black overflow-hidden rounded-b-3xl">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <!-- Content Container -->
  <div class="relative min-h-[650px] sm:min-h-[700px] lg:min-h-[800px] lg:h-[90vh] flex items-center justify-center pt-20 sm:pt-24 pb-8 sm:pb-12 lg:py-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        
        <!-- Left: Content -->
        <div class="text-white space-y-5 sm:space-y-6">
          <!-- Badge - Enhanced Visibility -->
          <div class="inline-flex items-center space-x-2 bg-red-600/30 border-2 border-red-400/50 rounded-full px-4 py-2 sm:px-5 sm:py-2.5 shadow-lg shadow-red-500/20">
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-red-400 animate-pulse" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span class="font-bold text-white text-sm sm:text-base">Trusted by 5,000+ Customers</span>
          </div>

          <!-- Main Heading -->
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black leading-tight">
            Sell Your Gold at
            <span class="text-red-400 block mt-2">Highest Market Rate</span>
          </h1>

          <!-- Subheading -->
          <p class="text-sm sm:text-base lg:text-xl text-gray-200 leading-relaxed max-w-2xl">
            Get instant cash for your old gold with transparent evaluation and free doorstep service in Coimbatore, Tiruppur & Theni.
          </p>

          <!-- Trust Badges Grid -->
          <div class="grid grid-cols-2 gap-2 sm:gap-3 pt-2 sm:pt-4">
            <div class="flex items-center space-x-2 bg-black/30 px-3 py-2 sm:px-4 sm:py-3 rounded-lg">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-xs sm:text-sm font-semibold">Best Price</span>
            </div>
            <div class="flex items-center space-x-2 bg-black/30 px-3 py-2 sm:px-4 sm:py-3 rounded-lg">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-xs sm:text-sm font-semibold">Instant Cash</span>
            </div>
            <div class="flex items-center space-x-2 bg-black/30 px-3 py-2 sm:px-4 sm:py-3 rounded-lg">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-xs sm:text-sm font-semibold">Free Service</span>
            </div>
            <div class="flex items-center space-x-2 bg-black/30 px-3 py-2 sm:px-4 sm:py-3 rounded-lg">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-xs sm:text-sm font-semibold">No Hidden Fee</span>
            </div>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 pt-3 sm:pt-4">
            <a 
              href="#contact" 
              class="inline-flex items-center justify-center bg-red-600 hover:bg-red-700 text-white font-bold px-6 py-3 sm:px-8 sm:py-4 rounded-lg shadow-lg transition-colors duration-200"
            >
              Sell Gold Now
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
            <a 
              href="tel:+917200090326" 
              class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white font-bold px-6 py-3 sm:px-8 sm:py-4 rounded-lg border-2 border-white/50 transition-colors duration-200"
            >
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
              Call +91 72000 90326
            </a>
          </div>
        </div>

        <!-- Right: Stats/Features -->
        <div class="hidden lg:grid grid-cols-2 gap-6">
          <!-- Stat Card 1 -->
          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 hover:bg-white/15 transition-colors">
            <div class="text-5xl font-black text-red-500 mb-2">5K+</div>
            <div class="text-white font-semibold">Happy Customers</div>
          </div>

          <!-- Stat Card 2 -->
          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 hover:bg-white/15 transition-colors">
            <div class="text-5xl font-black text-red-500 mb-2">100%</div>
            <div class="text-white font-semibold">Transparency</div>
          </div>

          <!-- Stat Card 3 -->
          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 hover:bg-white/15 transition-colors">
            <div class="text-5xl font-black text-red-500 mb-2">3</div>
            <div class="text-white font-semibold">Branch Locations</div>
          </div>

          <!-- Stat Card 4 -->
          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 hover:bg-white/15 transition-colors">
            <div class="text-5xl font-black text-red-500 mb-2">24/7</div>
            <div class="text-white font-semibold">Support Available</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
