    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden lg:hidden bg-gradient-to-b from-white to-gray-50 border-t border-gray-200 shadow-inner">
    <nav class="flex flex-col px-4 py-4">
      <a href="/" class="mobile-link text-gray-700 hover:text-[#7C0849] hover:bg-[#F8E8F1] font-semibold transition-all duration-200 py-3 px-4 rounded-lg">Home</a>
