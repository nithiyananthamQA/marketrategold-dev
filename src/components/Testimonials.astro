---
const testimonials = [
  {
    name: "Lakshmi Selvam",
    location: "Coimbatore",
    rating: 5,
    text: "Best gold buyers in Coimbatore! They offered the highest price for my old gold jewelry and the payment was instant. Very transparent process.",
    image: "👩"
  },
  {
    name: "Rajesh Kumar",
    location: "Tiruppur",
    rating: 5,
    text: "I was impressed with their doorstep service. The evaluation was done professionally right at my home. Highly recommended!",
    image: "👨"
  },
  {
    name: "Priya Venkatesh",
    location: "Coimbatore",
    rating: 5,
    text: "Released my pledged gold with their help. Got a much better rate than expected. Thank you MRG Gold Buyers!",
    image: "👩"
  },
  {
    name: "Murugan Samy",
    location: "Theni",
    rating: 5,
    text: "Trustworthy and professional team. No hidden charges, everything was transparent. Will definitely recommend to others.",
    image: "👨"
  },
  {
    name: "Deepa Ramesh",
    location: "Coimbatore",
    rating: 5,
    text: "Sold my broken gold ornaments and got instant cash. The whole process took less than 30 minutes. Excellent service!",
    image: "👩"
  },
  {
    name: "Vijay Anand",
    location: "Tiruppur",
    rating: 5,
    text: "Very satisfied with their service. They gave me the best market rate for my gold coins. Professional and courteous staff.",
    image: "👨"
  }
];
---

<section id="testimonials" class="py-12 sm:py-16 lg:py-20 bg-gradient-to-br from-white to-red-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
        Customer <span class="text-red-600">Testimonials</span>
      </h2>
      <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto">
        Trusted by thousands of customers across Tamil Nadu
      </p>
      <div class="flex items-center justify-center gap-2 mt-6">
        <div class="flex">
          {[1,2,3,4,5].map(() => (
            <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-gray-700 font-semibold ml-2">4.9/5 from 500+ reviews</span>
      </div>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {testimonials.map((testimonial, index) => (
        <div 
          class="testimonial-card bg-white rounded-xl sm:rounded-2xl p-6 sm:p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100"
          data-index={index}
        >
          <!-- Stars -->
          <div class="flex mb-4">
            {[...Array(testimonial.rating)].map(() => (
              <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Testimonial Text -->
          <p class="text-sm sm:text-base text-gray-700 leading-relaxed mb-6 italic">"{testimonial.text}"</p>

          <!-- Author -->
          <div class="flex items-center">
            <div class="w-12 h-12 bg-gradient-to-br from-red-500 to-red-700 rounded-full flex items-center justify-center text-2xl mr-4">
              {testimonial.image}
            </div>
            <div>
              <div class="font-bold text-gray-900">{testimonial.name}</div>
              <div class="text-sm text-gray-600">{testimonial.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Google Reviews CTA -->
    <div class="text-center mt-12">
      <p class="text-gray-600 mb-4">Read more reviews on</p>
      <a 
        href="#" 
        class="inline-flex items-center space-x-2 bg-white border-2 border-gray-300 hover:border-red-600 px-6 py-3 rounded-full font-semibold transition-all duration-300">
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span>Google Reviews</span>
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .testimonial-card {
      animation: fadeInUp 0.5s ease-out forwards;
      opacity: 0;
    }
    
    .testimonial-card:nth-child(1) { animation-delay: 0.1s; }
    .testimonial-card:nth-child(2) { animation-delay: 0.2s; }
    .testimonial-card:nth-child(3) { animation-delay: 0.3s; }
  }
  
  @media (prefers-reduced-motion: reduce) {
    .testimonial-card {
      opacity: 1;
    }
  }
</style>
