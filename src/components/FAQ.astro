---
const faqs = [
  {
    question: "What is the current gold rate in Coimbatore?",
    answer: "Our gold buying rates are based on the current market price and updated daily. We offer the highest rates in Coimbatore. Call us for today's live gold rate or check our website's live rate display."
  },
  {
    question: "Do you provide doorstep gold valuation service?",
    answer: "Yes! We offer free doorstep gold buying services across Coimbatore, Tiruppur, and Theni. Our experts will visit your location with professional equipment for safe and transparent evaluation."
  },
  {
    question: "How is my gold evaluated?",
    answer: "We use professional gold testing equipment to check the purity (22K, 18K, etc.) and precise digital scales for weight. The entire process is done transparently in front of you."
  },
  {
    question: "When will I receive payment?",
    answer: "Payment is instant! Once you approve the valuation, you'll receive payment immediately via cash, bank transfer, or UPI - whichever you prefer."
  },
  {
    question: "Are there any hidden charges or deductions?",
    answer: "Absolutely not! We believe in 100% transparency. You receive the exact calculated value of your gold with zero hidden charges or deductions."
  },
  {
    question: "What types of gold do you buy?",
    answer: "We buy all types of gold including old jewelry, broken ornaments, gold coins, gold bars, pledged gold, and second-hand gold jewelry of any purity."
  },
  {
    question: "Do I need to bring any documents?",
    answer: "For your protection and ours, we require a valid government ID (Aadhaar, PAN, Driving License, or Passport) for all gold transactions as per government regulations."
  },
  {
    question: "Can I release my pledged gold through you?",
    answer: "Yes! We help customers release pledged gold from other sources and often provide better rates. Bring your pledge receipt and we'll assist you with the process."
  }
];
---

<section id="faq" class="py-16 lg:py-20 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-3">
        Frequently Asked <span class="text-[#7C0849]">Questions</span>
      </h2>
      <p class="text-base lg:text-lg text-gray-600">
        Everything you need to know about selling gold to us
      </p>
    </div>

    <!-- FAQ Accordion -->
    <div class="space-y-3">
      {faqs.map((faq, index) => (
        <div 
          class="faq-item bg-white rounded-lg border border-gray-200 overflow-hidden hover:border-[#C65B91] hover:shadow-md transition-all duration-200"
          data-index={index}
        >
          <button 
            class="faq-question w-full text-left px-5 lg:px-6 py-4 lg:py-5 flex justify-between items-center gap-4 focus:outline-none group"
            aria-expanded="false"
          >
            <span class="text-base lg:text-lg font-semibold text-gray-900 leading-snug group-hover:text-[#7C0849] transition-colors">
              {faq.question}
            </span>
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[#F8E8F1] flex items-center justify-center group-hover:bg-[#F1D1E2] transition-all">
              <svg 
                class="faq-icon w-4 h-4 text-[#7C0849] transform transition-transform duration-200" 
                fill="none" 
                stroke="currentColor" 
                viewBox="0 0 24 24"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer hidden border-t border-gray-100">
            <div class="px-5 lg:px-6 py-4">
              <p class="text-sm lg:text-base text-gray-700 leading-relaxed">
                {faq.answer}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Still Have Questions CTA -->
    <div class="mt-12 text-center bg-gradient-to-br from-[#F8E8F1] to-orange-50 rounded-xl p-6 lg:p-8 border border-[#E3A3C5]">
      <h3 class="text-xl lg:text-2xl font-bold text-gray-900 mb-2">Still have questions?</h3>
      <p class="text-base text-gray-700 mb-6">
        Our expert team is available 24/7 to assist you
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a 
          href="tel:+917200090326" 
          class="inline-flex items-center justify-center space-x-2 bg-[#7C0849] hover:bg-[#650738] text-white px-6 py-3 rounded-lg font-semibold shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          <span>Call Us Now</span>
        </a>
        <a 
          href="https://wa.me/917200090326" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center space-x-2 bg-[#A7356D] hover:bg-[#650738] text-white px-6 py-3 rounded-lg font-semibold shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          <span>WhatsApp</span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  // FAQ Accordion functionality
  const faqQuestions = document.querySelectorAll('.faq-question');
  
  faqQuestions.forEach(question => {
    question.addEventListener('click', () => {
      const faqItem = question.closest('.faq-item');
      const answer = faqItem?.querySelector('.faq-answer');
      const icon = question.querySelector('.faq-icon');
      const isExpanded = question.getAttribute('aria-expanded') === 'true';
      
      // Close all other FAQs
      faqQuestions.forEach(q => {
        if (q !== question) {
          const otherItem = q.closest('.faq-item');
          const otherAnswer = otherItem?.querySelector('.faq-answer');
          const otherIcon = q.querySelector('.faq-icon');
          q.setAttribute('aria-expanded', 'false');
          otherAnswer?.classList.add('hidden');
          otherIcon?.classList.remove('rotate-180');
        }
      });
      
      // Toggle current FAQ
      if (isExpanded) {
        question.setAttribute('aria-expanded', 'false');
        answer?.classList.add('hidden');
        icon?.classList.remove('rotate-180');
      } else {
        question.setAttribute('aria-expanded', 'true');
        answer?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>
